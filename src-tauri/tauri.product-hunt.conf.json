{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glance Trial",
  "version": "0.3.8-5",
  "identifier": "com.glance.desktop.trial",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Glance Trial",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "backgroundColor": "#f3f4f7"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app",
      "msi",
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    },
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "12.0",
      "entitlements": "Glance.entitlements",
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://atglance.app/update-ph.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4NDVENzk3QjJFQjdEOUIKUldTYmZldXlsOWRGeUVFVVNoWHRUaWpVTVdzcG4wMjVhdllDL0QxWlBJVU9sWTFlejRVaXhOV1MK"
    }
  }
}
