{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for main and overlay windows",
  "windows": [
    "main",
    "overlay"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "core:default",
      "allow": [
        {
          "commands": [
            "get_monitors",
            "move_window_to_monitor"
          ]
        }
      ]
    },
    "dialog:default",
    "global-shortcut:default",
    "shell:default",
    "core:window:allow-set-position",
    "core:window:allow-set-size"
  ]
}
