{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for main and overlay windows",
  "windows": [
    "main",
    "overlay"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "global-shortcut:default",
    "shell:default"
  ]
}